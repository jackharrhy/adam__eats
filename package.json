{
  "name": "adam__eats",
  "type": "module",
  "version": "0.0.1",
  "packageManager": "pnpm@11.7.0",
  "emdash": {
    "seed": "seed/seed.json"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "start": "node ./dist/server/entry.mjs",
    "astro": "astro",
    "seed:generate": "node scripts/generate-seed.mjs",
    "typecheck": "astro check",
    "lint": "oxlint --type-aware --deny-warnings",
    "lint:fix": "oxlint --type-aware --fix",
    "format": "oxfmt --ignore-path .gitignore && prettier --write .",
    "format:check": "oxfmt --ignore-path .gitignore --check && prettier --check .",
    "knip": "knip --no-exit-code --exclude unlisted,unresolved,exports,types,duplicates"
  },
  "dependencies": {
    "@astrojs/node": "^11.0.0",
    "@astrojs/react": "^6.0.0",
    "@cooklang/cooklang": "^0.18.7",
    "astro": "^7.0.0",
    "better-sqlite3": "^12.8.0",
    "emdash": "^0.22.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "knip": "^6.17.1",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "oxlint-tsgolint": "^0.23.0",
    "prettier": "^3.8.4",
    "prettier-plugin-astro": "^0.14.1",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3"
  }
}
